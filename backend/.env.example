# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/products_shop

# Port the backend listens on
PORT=4000

# Comma-separated list of allowed origins for CORS (Next.js dev server)
CORS_ORIGIN=http://localhost:3000

# Shared only with the Next.js server. Use a strong random value.
INTERNAL_API_SECRET=replace-with-a-strong-random-secret
